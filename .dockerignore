# Secrets and env files with data - never go into the image
.env
.env.*
.env.example

# Git and history
.git
.gitignore
.github

# Dependencies - install inside the image
node_modules

# Build artifacts and cache — do NOT ignore .next, out, build, dist:
# they are created by `npm run build` in the container and must stay in the image (styles, static assets).
next-env.d.ts
*.tsbuildinfo

# Tests and coverage
coverage
**/__tests__
**/*.test.*
**/*.spec.*

# Documentation and runtime junk
*.md
!README.md
article
certbot
certs
www

# Local development and debugging
.DS_Store
*.log
.vercel

# IDE / Editor
.idea

# Docker files
.dockerignore
Dockerfile*

README.md
