{
  "id": null,
  "uid": "mongo-overview",
  "title": "MongoDB Overview (Telegraf)",
  "tags": ["mongo", "telegraf"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "type": "row",
      "title": "MongoDB Instance",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "panels": []
    },
    {
      "id": 1,
      "type": "stat",
      "title": "Connections current",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "targets": [
        {
          "expr": "mongodb_connections_current",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Ops per second (insert)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "targets": [
        {
          "expr": "rate(mongodb_insert_total[1m])",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Ops per second (query)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "targets": [
        {
          "expr": "rate(mongodb_query_total[1m])",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "graph",
      "title": "Document operations (per second)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 5 },
      "lines": true,
      "targets": [
        {
          "expr": "rate(mongodb_insert_total[5m])",
          "legendFormat": "insert",
          "refId": "A"
        },
        {
          "expr": "rate(mongodb_update_total[5m])",
          "legendFormat": "update",
          "refId": "B"
        },
        {
          "expr": "rate(mongodb_delete_total[5m])",
          "legendFormat": "delete",
          "refId": "C"
        }
      ]
    }
  ],
  "time": {
    "from": "now-15m",
    "to": "now"
  }
}

